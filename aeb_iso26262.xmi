<?xml version="1.0" encoding="UTF-8"?>
<raaml:SafetyAnalysis
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:raaml="http://edu.kit.sdq/dsis/metamodels/raaml"
    xmlns:raaml.hara="http://edu.kit.sdq/dsis/metamodels/raaml/hara"
    xmlns:raaml.req="http://edu.kit.sdq/dsis/metamodels/raaml/req"
    xmi:id="SA_AEB_ISO_001"
    id="SA_AEB_ISO_001"
    name="AEB ISO 26262 Full V-Model Analysis"
    description="Complete ISO 26262:2018 V-Model coverage for AEB: Item Definition, HARA, FSC, TSC, hardware and software requirements, verification and validation.">

  <analyses xsi:type="raaml.hara:ISO26262"
      xmi:id="ISO_AEB_001"
      id="ISO_AEB_001"
      name="AEB ISO 26262 Analysis - All Parts"
      description="Full ISO 26262:2018 Parts 3-6 coverage for AEB system.">

    <operationalSituations xsi:type="raaml.hara:OperationalSituation"
        xmi:id="ISO_OS_001" id="ISO_OS_001"
        name="OS-01: Urban Following - CCRs 10-50 km/h"
        description="PART:3|CLAUSE:5.4|Vehicle following lead vehicle at 10-50 km/h urban. Euro NCAP CCRs scenario. E4 daily exposure. High rear-end collision frequency in urban stop-go traffic."/>

    <operationalSituations xsi:type="raaml.hara:OperationalSituation"
        xmi:id="ISO_OS_002" id="ISO_OS_002"
        name="OS-02: Highway - CCRb 80-130 km/h"
        description="PART:3|CLAUSE:5.4|Vehicle closing on stationary lead vehicle at highway speed. Euro NCAP CCRb scenario. E3 frequency. High severity outcome due to closing speed."/>

    <operationalSituations xsi:type="raaml.hara:OperationalSituation"
        xmi:id="ISO_OS_003" id="ISO_OS_003"
        name="OS-03: Pedestrian Day - CPNA 20-60 km/h"
        description="PART:3|CLAUSE:5.4|Pedestrian crossing in daytime at vehicle speed 20-60 km/h. Euro NCAP CPNA-day. E4 daily urban. Pedestrian cannot avoid collision."/>

    <operationalSituations xsi:type="raaml.hara:OperationalSituation"
        xmi:id="ISO_OS_004" id="ISO_OS_004"
        name="OS-04: Pedestrian Night - CPNA less than 1 lux"
        description="PART:3|CLAUSE:5.4|Pedestrian crossing at night. Camera performance degraded. Euro NCAP CPNA-night. E3 frequency. C3 pedestrian unaware."/>

    <operationalSituations xsi:type="raaml.hara:OperationalSituation"
        xmi:id="ISO_OS_005" id="ISO_OS_005"
        name="OS-05: Adverse Weather - Rain/Fog/Snow"
        description="PART:3|CLAUSE:5.4|Sensor performance degraded by precipitation. E2 frequency. Both radar and camera affected differently. Driver visibility also impaired."/>

    <malfunctioningBehaviors xsi:type="raaml.hara:MalfunctioningBehaviour"
        xmi:id="ISO_MB_001" id="ISO_MB_001"
        name="MB-01: AEB Fails to Activate"
        description="PART:3|CLAUSE:5.4.3|Complete loss of AEB braking function when collision imminent. Covers sensor failure, ECU failure, actuator failure chains."/>

    <malfunctioningBehaviors xsi:type="raaml.hara:MalfunctioningBehaviour"
        xmi:id="ISO_MB_002" id="ISO_MB_002"
        name="MB-02: AEB Activates Without Threat"
        description="PART:3|CLAUSE:5.4.3|Emergency braking applied when no valid obstacle exists. False positive from sensor or fusion logic error."/>

    <malfunctioningBehaviors xsi:type="raaml.hara:MalfunctioningBehaviour"
        xmi:id="ISO_MB_003" id="ISO_MB_003"
        name="MB-03: AEB Activates Too Late"
        description="PART:3|CLAUSE:5.4.3|Braking initiated beyond FTTI - too late to avoid collision at given speed. Latency in sensor chain or processing."/>

    <malfunctioningBehaviors xsi:type="raaml.hara:MalfunctioningBehaviour"
        xmi:id="ISO_MB_004" id="ISO_MB_004"
        name="MB-04: Insufficient Deceleration"
        description="PART:3|CLAUSE:5.4.3|AEB activates but achieves less than minimum required deceleration. Actuator degradation or partial valve failure."/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ISO_ASIL_001" id="ISO_ASIL_001"
        name="HE-01: MB-01 in OS-01 Urban - ASIL-D"
        description="PART:3|TABLE:4|S3 life-threatening rear-end at 50km/h|E4 daily commute|C3 driver cannot react in TTC less than 1.5s|RESULT:ASIL-D|REF:ISO 26262:2018 Part 3 Table 4, SAE J2980 Table 1"
        ASIL="D"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ISO_ASIL_002" id="ISO_ASIL_002"
        name="HE-02: MB-01 in OS-02 Highway - ASIL-D"
        description="PART:3|TABLE:4|S3 fatality probable at 130km/h|E3 motorway travel|C3 no driver reaction above 120km/h|RESULT:ASIL-D|REF:ISO 26262:2018 Part 3 Table 4"
        ASIL="D"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ISO_ASIL_003" id="ISO_ASIL_003"
        name="HE-03: MB-02 Highway False Activation - ASIL-C"
        description="PART:3|TABLE:4|S3 following vehicle collision at 130km/h|E3 highway exposure|C2 following driver may partially react|RESULT:ASIL-C|REF:ISO 26262:2018 Part 3 Table 4"
        ASIL="C"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ISO_ASIL_004" id="ISO_ASIL_004"
        name="HE-04: MB-01 Pedestrian Day - ASIL-D"
        description="PART:3|TABLE:4|S3 pedestrian fatality|E4 daily urban driving|C3 pedestrian cannot avoid vehicle|RESULT:ASIL-D|REF:Euro NCAP VRU Protocol v4.5.1"
        ASIL="D"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ISO_ASIL_005" id="ISO_ASIL_005"
        name="HE-05: MB-01 Pedestrian Night - ASIL-D"
        description="PART:3|TABLE:4|S3 pedestrian fatality|E3 night driving frequency|C3 pedestrian unaware of vehicle|RESULT:ASIL-D|REF:Euro NCAP VRU Protocol v4.5.1 CPNA-night"
        ASIL="D"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ISO_ASIL_006" id="ISO_ASIL_006"
        name="HE-06: MB-03 Late Activation Highway - ASIL-D"
        description="PART:3|TABLE:4|S3 FTTI violation renders AEB ineffective|E3 highway|C3 no driver reaction time|RESULT:ASIL-D|REF:MDPI AEB 2021 FTTI=150ms analysis"
        ASIL="D"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ISO_ASIL_007" id="ISO_ASIL_007"
        name="HE-07: MB-04 Insufficient Decel Urban - ASIL-B"
        description="PART:3|TABLE:4|S2 serious injury probable at reduced decel|E4 daily exposure|C2 driver may supplement braking|RESULT:ASIL-B|REF:ISO 26262:2018 Part 3 Table 4"
        ASIL="B"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ISO_ASIL_008" id="ISO_ASIL_008"
        name="HE-08: MB-02 False Activation Parking - QM"
        description="PART:3|TABLE:4|S1 minor injury at 0-15km/h|E3 parking frequency|C2 driver can override|RESULT:QM|REF:ISO 26262:2018 Part 3 Table 4"
        ASIL="QM"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ISO_ASIL_009" id="ISO_ASIL_009"
        name="HE-09: MB-01 Adverse Weather - ASIL-C"
        description="PART:3|TABLE:4|S3 collision in reduced visibility|E2 adverse weather less frequent|C3 driver visibility also impaired|RESULT:ASIL-C|REF:Singh and Gabbar 2019"
        ASIL="C"/>

    <verifiedItems xsi:type="raaml.hara:Verified"
        xmi:id="ISO_VER_001" id="ISO_VER_001"
        name="HARA Verification - ISO 26262:2018 Part 3"
        result="PART:3|Verified against ISO 26262:2018 Part 3. ASIL assignments cross-checked with SAE J2980:2018 Table 1. Operational situations validated against Euro NCAP AEB C2C v4.3.1 and VRU v4.5.1. Independent review completed."/>

    <verifiedItems xsi:type="raaml.hara:Verified"
        xmi:id="ISO_VER_002" id="ISO_VER_002"
        name="FSC Verification - ISO 26262:2018 Part 4"
        result="PART:4|Functional Safety Concept verified. Safety goals SG-01 to SG-05 traceable to HARA. FTTI values confirmed by MDPI AEB Hardware 2021. Safe states defined per Part 4 Clause 8.4.5."/>

    <verifiedItems xsi:type="raaml.hara:Verified"
        xmi:id="ISO_VER_003" id="ISO_VER_003"
        name="Hardware Verification - ISO 26262:2018 Part 5"
        result="PART:5|PMHF target 1e-8/h per Part 5 Table 6. Reference architecture achieves 3.2e-9/h. HFT=1 dual-channel verified. SPFM and LFM metrics computed per Part 5 Annex D."/>

    <verifiedItems xsi:type="raaml.hara:Verified"
        xmi:id="ISO_VER_004" id="ISO_VER_004"
        name="Software Verification - ISO 26262:2018 Part 6"
        result="PART:6|Software ASIL-D methods applied: formal methods for TTC algorithm, MC/DC coverage, code review. ECC memory, watchdog, E2E CRC per Part 6 Annex D Table D.2."/>

    <confirmedItems xsi:type="raaml.hara:Confirmed"
        xmi:id="ISO_CONF_001" id="ISO_CONF_001"
        name="Safety Case Confirmation"
        result="PART:2|All safety goals confirmed by independent safety assessor. DIA - Development Interface Agreement with Tier-1 supplier documented. Safety manual created per Part 8."/>

  </analyses>

</raaml:SafetyAnalysis>