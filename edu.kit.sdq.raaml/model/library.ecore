<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="library" nsURI="http://edu.kit.sdq/dsis/metamodels/raaml/library"
    nsPrefix="library">
  <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
    <details key="documentation" value="General-purpose library for reusable safety analysis elements"/>
  </eAnnotations>
  <eClassifiers xsi:type="ecore:EClass" name="GeneralLibrary" eSuperTypes="core.ecore#//AbstractLibrary">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="A general-purpose library that can contain any type of situation elements for reuse across multiple safety analyses"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Package"/>
      <details key="stereotype" value="GeneralLibrary"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EReference" name="anySituations" upperBound="-1"
        eType="ecore:EClass core.ecore#//AnySituation" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Collection of reusable situation elements (factors, scenarios, events, etc.)"/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>
</ecore:EPackage>
