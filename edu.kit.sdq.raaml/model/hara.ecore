  <eClassifiers xsi:type="ecore:EClass" name="ISO26262Library" eSuperTypes="core.ecore#//AbstractLibrary">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Reusable library of ISO 26262 elements"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Package"/>
      <details key="stereotype" value="ISO26262Library"/>
