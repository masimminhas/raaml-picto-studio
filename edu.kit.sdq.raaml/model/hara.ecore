      <details key="base" value="Class"/>
      <details key="stereotype" value="EnvironmentalCondition"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TypicalAutomotiveSituation" abstract="true"
      eSuperTypes="#//AbstractOperationalSituation">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="RAAML ISO26262 Library: typical automotive operational situation aggregating five contextual dimensions (traffic, usage, road, location, environment)"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="TypicalAutomotiveSituation"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EReference" name="trafficAndPeople" upperBound="-1"
        eType="#//TrafficAndPeople" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="vehicleUsage" upperBound="-1"
        eType="#//VehicleUsage" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="roadCondition" upperBound="-1"
        eType="#//RoadCondition" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="location" upperBound="-1"
        eType="#//Location" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="environmentalCondition" upperBound="-1"
        eType="#//EnvironmentalCondition" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="AccidentScenario" abstract="true" eSuperTypes="core.ecore#//DysfunctionalEvent">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Scenario leading to an accident"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="controllability" eType="#//Controllability"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="situations" upperBound="-1"
        eType="#//AbstractOperationalSituation" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="malfunctioningBehaviors"
        upperBound="-1" eType="#//AnyMalfunction" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="AnyMalfunction" abstract="true" eSuperTypes="core.ecore#//UndesiredState">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Base class for malfunctions"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="More" eSuperTypes="#//AnyMalfunction">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="RAAML ISO26262 Library: malfunction with more-than-intended magnitude (HAZOP guide-word: MORE)"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="More"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Less" eSuperTypes="#//AnyMalfunction">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="RAAML ISO26262 Library: malfunction with less-than-intended magnitude (HAZOP guide-word: LESS)"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="Less"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="No" eSuperTypes="#//AnyMalfunction">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="RAAML ISO26262 Library: function not delivered (HAZOP guide-word: NO/NOT)"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="No"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Intermittent" eSuperTypes="#//AnyMalfunction">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="RAAML ISO26262 Library: function delivered intermittently (HAZOP guide-word equivalent)"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="Intermittent"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Unintended" eSuperTypes="#//AnyMalfunction">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="RAAML ISO26262 Library: function delivered when not intended (HAZOP guide-word: OTHER_THAN/AS_WELL_AS)"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="Unintended"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Early" eSuperTypes="#//AnyMalfunction">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="RAAML ISO26262 Library: function delivered too early (HAZOP guide-word: EARLY/BEFORE)"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="Early"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Late" eSuperTypes="#//AnyMalfunction">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="RAAML ISO26262 Library: function delivered too late (HAZOP guide-word: LATE/AFTER)"/>
