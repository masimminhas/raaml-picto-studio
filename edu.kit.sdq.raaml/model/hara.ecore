  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ASILAssignment" eSuperTypes="core.ecore#//CoreSafetyElement">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="ASIL assignment and override"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="ASILAssignment"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="ASIL" lowerBound="1" eType="#//ASIL"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="ASILOverride" eType="#//ASIL"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="OperationalCondition" abstract="true"
      eSuperTypes="core.ecore#//AbstractEvent">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Operating condition for hazard analysis"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="AbstractOperationalSituation" abstract="true"
      eSuperTypes="#//OperationalCondition">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Operational situation with exposure rating"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="exposure" eType="#//Exposure"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="conditions" upperBound="-1"
        eType="#//OperationalCondition" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TrafficAndPeople" abstract="true"
