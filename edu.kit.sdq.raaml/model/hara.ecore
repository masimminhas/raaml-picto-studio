<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="hara" nsURI="http://edu.kit.sdq/dsis/metamodels/raaml/hara"
    nsPrefix="hara">
  <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
    <details key="documentation" value="ISO 26262 Hazard Analysis and Risk Assessment"/>
  </eAnnotations>
  <eClassifiers xsi:type="ecore:EClass" name="ISO26262" eSuperTypes="core.ecore#//Analysis">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="ISO 26262 HARA container"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Package"/>
      <details key="stereotype" value="ISO26262"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EReference" name="malfunctioningBehaviors"
        upperBound="-1" eType="#//MalfunctioningBehaviour" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="operationalSituations"
        upperBound="-1" eType="#//OperationalSituation" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="confirmedItems" upperBound="-1"
        eType="#//Confirmed" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="verifiedItems" upperBound="-1"
        eType="#//Verified" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="asilAssignments" upperBound="-1"
        eType="#//ASILAssignment" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="ASIL">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Automotive Safety Integrity Level"/>
    </eAnnotations>
    <eLiterals name="noassignment" literal="noassignment"/>
    <eLiterals name="QM" value="1" literal="QM"/>
    <eLiterals name="A" value="2" literal="A"/>
    <eLiterals name="B" value="3" literal="B"/>
    <eLiterals name="C" value="4" literal="C"/>
    <eLiterals name="D" value="5" literal="D"/>
    <eLiterals name="AB" value="6" literal="AB"/>
    <eLiterals name="AC" value="7" literal="AC"/>
    <eLiterals name="AD" value="8" literal="AD"/>
    <eLiterals name="BC" value="9" literal="BC"/>
    <eLiterals name="CD" value="10" literal="CD"/>
    <eLiterals name="AA" value="11" literal="AA"/>
    <eLiterals name="BB" value="12" literal="BB"/>
    <eLiterals name="CC" value="13" literal="CC"/>
    <eLiterals name="DD" value="14" literal="DD"/>
    <eLiterals name="QMA" value="15" literal="QMA"/>
    <eLiterals name="QMB" value="16" literal="QMB"/>
    <eLiterals name="QMC" value="17" literal="QMC"/>
    <eLiterals name="QMD" value="18" literal="QMD"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="Controllability">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="ISO 26262 controllability rating"/>
    </eAnnotations>
    <eLiterals name="C0" literal="C0"/>
    <eLiterals name="C1" value="1" literal="C1"/>
    <eLiterals name="C2" value="2" literal="C2"/>
    <eLiterals name="C3" value="3" literal="C3"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="Exposure">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="ISO 26262 exposure rating"/>
    </eAnnotations>
    <eLiterals name="E0" literal="E0"/>
    <eLiterals name="E1" value="1" literal="E1"/>
    <eLiterals name="E2" value="2" literal="E2"/>
    <eLiterals name="E3" value="3" literal="E3"/>
    <eLiterals name="E4" value="4" literal="E4"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="Severity">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="ISO 26262 severity rating"/>
    </eAnnotations>
    <eLiterals name="S0" literal="S0"/>
    <eLiterals name="S1" value="1" literal="S1"/>
    <eLiterals name="S2" value="2" literal="S2"/>
    <eLiterals name="S3" value="3" literal="S3"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="OperationalSituation" eSuperTypes="core.ecore#//Situation">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Operating scenario for the item"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="OperationalSituation"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="MalfunctioningBehaviour" eSuperTypes="core.ecore#//FailureMode">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Malfunctioning behavior of the item"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="MalfunctioningBehaviour"/>
