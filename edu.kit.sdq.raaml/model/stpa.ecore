      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Actuators in the control structure"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="sensors" upperBound="-1"
        eType="#//Sensor" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Sensors in the control structure"/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Controller" eSuperTypes="core.ecore#//CoreSafetyElement">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="A controller that issues control actions"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="Controller"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EReference" name="controlActions" upperBound="-1"
        eType="#//ControlAction" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Control actions issued by this controller"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="feedback" upperBound="-1"
        eType="#//Feedback" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Feedback received by this controller"/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ControlledProcess" eSuperTypes="core.ecore#//CoreSafetyElement">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="A process that is controlled"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="ControlledProcess"/>
