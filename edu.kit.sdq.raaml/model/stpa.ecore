    <eStructuralFeatures xsi:type="ecore:EReference" name="controlStructures" upperBound="-1"
        eType="#//ControlStructure" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="controlActions" upperBound="-1"
        eType="#//ControlAction" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="unsafeControlActions" upperBound="-1"
        eType="#//UndesiredControlAction" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ProcessModelFlaw" eSuperTypes="core.ecore#//AnySituation">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="A flaw in the control process model (STPA)"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="ProcessModelFlaw"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EReference" name="causalFactor" upperBound="-1"
        eType="ecore:EClass core.ecore#//Factor">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Causal factors of this process model flaw"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="undesiredControlAction"
        upperBound="-1" eType="#//UndesiredControlAction">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Undesired control actions resulting from this flaw"/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="HarmPotential" abstract="true" eSuperTypes="core.ecore#//CoreSafetyElement">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Potential for harm or adverse effects"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="HarmPotential"/>
