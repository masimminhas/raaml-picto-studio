<?xml version="1.0" encoding="UTF-8"?>
<project default="run-backward" basedir=".">
    <taskdef resource="org/eclipse/epsilon/workflow/tasks/tasks.xml"/>
    <taskdef resource="org/eclipse/epsilon/workflow/tasks/emf/tasks.xml"/>
    <taskdef name="epsilon.etl"
             classname="org.eclipse.epsilon.workflow.tasks.EtlTask"
             onerror="ignore"/>

    <property name="project.dir"   location="${basedir}/.."/>
    <property name="workspace.dir" location="${basedir}/../.."/>
    <property name="raaml.ecore"
              location="${workspace.dir}/edu.kit.sdq.raaml/model/raaml.ecore"/>
    <property name="ecore.source"
              location="${basedir}/samples/aeb_gsn_usermodel.raaml.xmi"/>
    <property name="uml.target"
              location="${basedir}/samples/aeb_gsn_usermodel_roundtrip.uml"/>

    <target name="run-backward">
        <echo>Pair 2 user-model GSN backward (Ecore -> UML)</echo>
        <available file="${ecore.source}" property="src.exists"/>
        <fail unless="src.exists">Source not found: ${ecore.source}</fail>

        <epsilon.emf.loadModel name="RAAML"
                               modelfile="${ecore.source}"
                               metamodeluri="http://edu.kit.sdq/dsis/metamodels/raaml,http://edu.kit.sdq/dsis/metamodels/raaml/core,http://edu.kit.sdq/dsis/metamodels/raaml/fmea,http://edu.kit.sdq/dsis/metamodels/raaml/fta,http://edu.kit.sdq/dsis/metamodels/raaml/hara,http://edu.kit.sdq/dsis/metamodels/raaml/stpa,http://edu.kit.sdq/dsis/metamodels/raaml/gsn,http://edu.kit.sdq/dsis/metamodels/raaml/req,http://edu.kit.sdq/dsis/metamodels/raaml/library"
                               read="true" store="false" expand="true"/>
        <epsilon.emf.loadModel name="UML"
                               modelfile="${uml.target}"
                               metamodeluri="http://www.eclipse.org/uml2/5.0.0/UML"
                               read="false" store="true" expand="true"/>

        <epsilon.etl src="${basedir}/pair2-usermodel-gsn-backward.etl">
            <model ref="RAAML"/>
            <model ref="UML"/>
        </epsilon.etl>
        <epsilon.disposeModels/>
        <echo>Done. Inspect: ${uml.target}</echo>
    </target>
</project>
