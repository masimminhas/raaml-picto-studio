    transform s : RAAML!gsn!Context
    to t : UML!Class {

    if (s.name <> null) { t.name = s.name; }
    post {
        t.applyRAAMLStereotype('Context');
        if (s.id <> null) {
            t.setTaggedValue('Context', 'id', s.id);
        }
        if (s.description <> null) {
            t.setTaggedValue('Context', 'description', s.description);
        }
        if (s.visibility <> null) {
            t.setTaggedValue('Context', 'visibility', s.visibility);
        }
        if (s.contextId <> null) {
            t.setTaggedValue('Context', 'contextId', s.contextId);
        }
    }
}

