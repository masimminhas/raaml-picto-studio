// RAAML core!Situation -> UML Class with <<Situation>>
// ----------------------------------------------------------------------------
rule Reverse_Situation
    transform s : RAAML!core!Situation
    to t : UML!Class {

    if (s.name <> null) { t.name = s.name; }
    post {
        t.applyRAAMLStereotype('Situation');
        if (s.id <> null) {
            t.setTaggedValue('Situation', 'id', s.id);
        }
        if (s.description <> null) {
            t.setTaggedValue('Situation', 'description', s.description);
        }
        if (s.visibility <> null) {
            t.setTaggedValue('Situation', 'visibility', s.visibility);
        }
    }
}

