// ----------------------------------------------------------------------------
// UML Package with <<FTA>> -> RAAML fta!FTA
// ----------------------------------------------------------------------------
rule Transform_FTA
    transform s : UML!Package
    to t : RAAML!fta!FTA {

    guard : s.hasStereotype('FTA')

    t.name = s.name;
    if (s.getTaggedValue('FTA', 'id') <> null) {
        t.id = s.getTaggedValue('FTA', 'id');
    }
    if (s.getTaggedValue('FTA', 'description') <> null) {
        t.description = s.getTaggedValue('FTA', 'description');
    }
    if (s.getTaggedValue('FTA', 'visibility') <> null) {
        t.visibility = s.getTaggedValue('FTA', 'visibility');
    }
    // Containment: owned elements with <<FTATree>>
    t.trees ::= s.getOwnedElementsByStereotype('FTATree');
}

