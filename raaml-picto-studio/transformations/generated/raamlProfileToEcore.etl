// ----------------------------------------------------------------------------
// UML Package with <<STPALibrary>> -> RAAML stpa!STPALibrary
// ----------------------------------------------------------------------------
rule Transform_STPALibrary
    transform s : UML!Package
    to t : RAAML!stpa!STPALibrary {

    guard : s.hasStereotype('STPALibrary')

    t.name = s.name;
    if (s.getTaggedValue('STPALibrary', 'id') <> null) {
        t.id = s.getTaggedValue('STPALibrary', 'id');
    }
    if (s.getTaggedValue('STPALibrary', 'description') <> null) {
        t.description = s.getTaggedValue('STPALibrary', 'description');
    }
    if (s.getTaggedValue('STPALibrary', 'visibility') <> null) {
        t.visibility = s.getTaggedValue('STPALibrary', 'visibility');
    }
    // Containment: owned elements with <<ControlStructure>>
    t.controlStructures ::= s.getOwnedElementsByStereotype('ControlStructure');
    // Containment: owned elements with <<ControlAction>>
    t.controlActions ::= s.getOwnedElementsByStereotype('ControlAction');
    // Containment: owned elements with <<UndesiredControlAction>>
    t.unsafeControlActions ::= s.getOwnedElementsByStereotype('UndesiredControlAction');
}

// ----------------------------------------------------------------------------
// UML Package with <<GSN>> -> RAAML gsn!GSN
// ----------------------------------------------------------------------------
rule Transform_GSN
    transform s : UML!Package
    to t : RAAML!gsn!GSN {

    guard : s.hasStereotype('GSN')

    t.name = s.name;
    if (s.getTaggedValue('GSN', 'id') <> null) {
        t.id = s.getTaggedValue('GSN', 'id');
    }
    if (s.getTaggedValue('GSN', 'description') <> null) {
        t.description = s.getTaggedValue('GSN', 'description');
    }
    if (s.getTaggedValue('GSN', 'visibility') <> null) {
        t.visibility = s.getTaggedValue('GSN', 'visibility');
    }
    // Containment: owned elements with <<SupportedBy>>
    t.supportedBy ::= s.getOwnedElementsByStereotype('SupportedBy');
    // Containment: owned elements with <<InContextOf>>
    t.inContextOf ::= s.getOwnedElementsByStereotype('InContextOf');
}

