// UML Class with <<Situation>> -> RAAML core!Situation
// ----------------------------------------------------------------------------
rule Transform_Situation
    transform s : UML!Class
    to t : RAAML!core!Situation {

    guard : s.hasStereotype('Situation')

    t.name = s.name;
    if (s.getTaggedValue('Situation', 'id') <> null) {
        t.id = s.getTaggedValue('Situation', 'id');
    }
    if (s.getTaggedValue('Situation', 'description') <> null) {
        t.description = s.getTaggedValue('Situation', 'description');
    }
    if (s.getTaggedValue('Situation', 'visibility') <> null) {
        t.visibility = s.getTaggedValue('Situation', 'visibility');
    }
}

