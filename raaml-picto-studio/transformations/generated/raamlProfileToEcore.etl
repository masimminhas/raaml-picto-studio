// UML Class with <<ControlledProcess>> -> RAAML stpa!ControlledProcess
// ----------------------------------------------------------------------------
rule Transform_ControlledProcess
    transform s : UML!Class
    to t : RAAML!stpa!ControlledProcess {

    guard : s.hasStereotype('ControlledProcess')

    t.name = s.name;
    if (s.getTaggedValue('ControlledProcess', 'id') <> null) {
        t.id = s.getTaggedValue('ControlledProcess', 'id');
    }
    if (s.getTaggedValue('ControlledProcess', 'description') <> null) {
        t.description = s.getTaggedValue('ControlledProcess', 'description');
    }
    if (s.getTaggedValue('ControlledProcess', 'visibility') <> null) {
        t.visibility = s.getTaggedValue('ControlledProcess', 'visibility');
    }
}

