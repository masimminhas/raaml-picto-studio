<?xml version="1.0" encoding="UTF-8"?>
<!--
  aeb_hazop.raaml.xmi
  =====================================================================
  AEB HAZOP sample, migrated from the previous description-field-encoded
  format (aeb_hazop.xmi) to first-class typed HAZOP elements per the
  new hazop sub-package added to raaml.ecore.

  15 deviations across 7 nodes; guide words and risk levels are now
  typed enum literals rather than substrings of the description field.
  =====================================================================
-->
<raaml:SafetyAnalysis
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:raaml="http://edu.kit.sdq/dsis/metamodels/raaml"
    xmlns:raaml.hazop="http://edu.kit.sdq/dsis/metamodels/raaml/hazop"
    xmi:id="SA_AEB_HAZOP_001"
    id="SA_AEB_HAZOP_001"
    name="AEB HAZOP Safety Analysis"
    description="HAZOP for AEB System per IEC 61882:2016.">

  <analyses xsi:type="raaml.hazop:HAZOPStudy"
      xmi:id="HAZOP_AEB_001" id="HAZOP_AEB_001"
      name="AEB System HAZOP"
      description="Guide-word deviation analysis on AEB subsystems."
      studyDate="2026-05-16"
      standardReference="IEC 61882:2016">

    <!-- =================== Node: Radar Sensor =================== -->
    <nodes id="N_Radar" name="Radar Sensor"
        subsystem="Radar Sensor"
        designIntent="Detect obstacles ahead and report range, velocity, and classification to the AEB ECU within FTTI">

      <deviations id="HZ_001" name="HZ-01: NO SIGNAL - Radar Sensor Output"
          guideWord="NO" parameter="Obstacle detection signal"
          deviationText="No radar signal output to ECU"
          riskLevel="CRITICAL" asil="D">
        <causes id="HZ_001_C1" name="Transceiver hardware failure"/>
        <causes id="HZ_001_C2" name="Power loss"/>
        <causes id="HZ_001_C3" name="Antenna disconnection"/>
        <consequences id="HZ_001_X1"
            name="AEB cannot detect obstacle, no emergency braking, rear-end collision risk"/>
        <safeguards id="HZ_001_S1" name="Camera redundancy"/>
        <safeguards id="HZ_001_S2" name="CAN E2E timeout detection"/>
        <safeguards id="HZ_001_S3" name="AEB warning lamp"/>
        <recommendations id="HZ_001_R1"
            name="Implement HFT=1 dual-channel sensing per ISO 26262 Part 5"/>
      </deviations>

      <deviations id="HZ_002" name="HZ-02: MORE - Radar Detection Range"
          guideWord="MORE" parameter="Detection range"
          deviationText="Radar reports obstacles beyond actual range"
          riskLevel="HIGH" asil="C">
        <causes id="HZ_002_C1" name="Gain miscalibration"/>
        <causes id="HZ_002_C2" name="Multipath amplification"/>
        <consequences id="HZ_002_X1"
            name="Premature AEB activation at safe following distance"/>
        <safeguards id="HZ_002_S1" name="Sensor fusion cross-validation"/>
        <safeguards id="HZ_002_S2" name="Plausibility check"/>
        <recommendations id="HZ_002_R1"
            name="Camera cross-validation mandatory above 80km/h"/>
      </deviations>

      <deviations id="HZ_003" name="HZ-03: LESS - Radar Detection Range"
          guideWord="LESS" parameter="Detection range"
          deviationText="Radar effective range reduced below 60m"
          riskLevel="CRITICAL" asil="D">
        <causes id="HZ_003_C1" name="Radome contamination"/>
        <causes id="HZ_003_C2" name="Antenna degradation"/>
        <causes id="HZ_003_C3" name="Ice or dirt accumulation"/>
        <consequences id="HZ_003_X1"
            name="Insufficient TTC for highway braking, late or no AEB response"/>
        <safeguards id="HZ_003_S1" name="Radome self-diagnostic"/>
        <safeguards id="HZ_003_S2" name="Degraded mode warning"/>
        <safeguards id="HZ_003_S3" name="Range monitoring"/>
        <recommendations id="HZ_003_R1"
            name="Implement online range self-test, driver warning on degradation"/>
      </deviations>

      <deviations id="HZ_004" name="HZ-04: OTHER THAN - Radar Target Classification"
          guideWord="OTHER THAN" parameter="Target type classification"
          deviationText="Ghost target from multipath reflection classified as real vehicle"
          riskLevel="HIGH" asil="C">
        <causes id="HZ_004_C1" name="Highway infrastructure reflections"/>
        <causes id="HZ_004_C2" name="Wet road"/>
        <causes id="HZ_004_C3" name="Metal guardrails"/>
        <consequences id="HZ_004_X1"
            name="False AEB activation causing rear-end risk from following vehicle"/>
        <safeguards id="HZ_004_S1" name="Doppler velocity cross-check"/>
        <safeguards id="HZ_004_S2" name="Camera confirmation"/>
        <safeguards id="HZ_004_S3" name="Track history filter"/>
        <recommendations id="HZ_004_R1"
            name="Minimum 2-scan track confirmation before AEB authorisation"/>
      </deviations>

      <deviations id="HZ_005" name="HZ-05: LATE - Radar Signal Processing"
          guideWord="LATE" parameter="Signal processing latency"
          deviationText="Radar object data arrives at ECU after FTTI deadline"
          riskLevel="CRITICAL" asil="D">
        <causes id="HZ_005_C1" name="DSP overload"/>
        <causes id="HZ_005_C2" name="CAN bus congestion"/>
        <causes id="HZ_005_C3" name="Processing pipeline stall"/>
        <consequences id="HZ_005_X1"
            name="TTC calculation based on stale data, AEB activation too late"/>
        <safeguards id="HZ_005_S1" name="CAN E2E sequence counter"/>
        <safeguards id="HZ_005_S2" name="Watchdog"/>
        <safeguards id="HZ_005_S3" name="FTTI monitoring"/>
        <recommendations id="HZ_005_R1"
            name="Guarantee maximum sensor-to-ECU latency of 20ms per FTTI budget"/>
      </deviations>
    </nodes>

    <!-- =================== Node: AEB ECU =================== -->
    <nodes id="N_ECU" name="AEB ECU"
        subsystem="AEB Electronic Control Unit"
        designIntent="Compute time-to-collision and decide on emergency braking activation">

      <deviations id="HZ_006" name="HZ-06: NO FUNCTION - AEB ECU Processing"
          guideWord="NO" parameter="Collision threat computation"
          deviationText="ECU produces no braking decision output"
          riskLevel="CRITICAL" asil="D">
        <causes id="HZ_006_C1" name="MCU hardware fault"/>
        <causes id="HZ_006_C2" name="Power supply failure"/>
        <causes id="HZ_006_C3" name="Software deadlock"/>
        <consequences id="HZ_006_X1"
            name="Complete AEB function loss, no warning, no braking"/>
        <safeguards id="HZ_006_S1" name="Hardware watchdog 50ms"/>
        <safeguards id="HZ_006_S2" name="Dual MCU lockstep"/>
        <safeguards id="HZ_006_S3" name="Safe state transition"/>
        <recommendations id="HZ_006_R1"
            name="Lockstep MCU architecture, watchdog reset to safe state within FTTI"/>
      </deviations>

      <deviations id="HZ_007" name="HZ-07: OTHER THAN - ECU TTC Calculation"
          guideWord="OTHER THAN" parameter="Time-to-collision value"
          deviationText="ECU computes incorrect TTC due to memory corruption"
          riskLevel="HIGH" asil="D">
        <causes id="HZ_007_C1" name="SRAM bit-flip from SEU"/>
        <causes id="HZ_007_C2" name="Stack overflow"/>
        <causes id="HZ_007_C3" name="Corrupted calibration data"/>
        <consequences id="HZ_007_X1"
            name="Wrong activation threshold, missed or false AEB activation"/>
        <safeguards id="HZ_007_S1" name="ECC memory"/>
        <safeguards id="HZ_007_S2" name="CRC on parameters"/>
        <safeguards id="HZ_007_S3" name="BIST at startup"/>
        <recommendations id="HZ_007_R1"
            name="ECC SRAM mandatory, periodic parameter CRC check at 100ms interval"/>
      </deviations>
    </nodes>

    <!-- =================== Node: Hydraulic Brake Actuator =================== -->
    <nodes id="N_Brake" name="Hydraulic Brake Actuator"
        subsystem="Hydraulic Brake Actuator"
        designIntent="Apply commanded deceleration on AEB request">

      <deviations id="HZ_008" name="HZ-08: NO PRESSURE - Brake Actuator"
          guideWord="NO" parameter="Brake pressure output"
          deviationText="Zero brake pressure despite AEB command"
          riskLevel="CRITICAL" asil="D">
        <causes id="HZ_008_C1" name="Solenoid valve stuck closed"/>
        <causes id="HZ_008_C2" name="Hydraulic pump failure"/>
        <causes id="HZ_008_C3" name="Seal leak"/>
        <consequences id="HZ_008_X1"
            name="AEB activates but vehicle does not decelerate, silent failure"/>
        <safeguards id="HZ_008_S1" name="Brake pressure sensor feedback"/>
        <safeguards id="HZ_008_S2" name="Actuator BIST"/>
        <safeguards id="HZ_008_S3" name="Pressure plausibility check"/>
        <recommendations id="HZ_008_R1"
            name="Redundant pressure sensors, BIST every ignition cycle"/>
      </deviations>

      <deviations id="HZ_009" name="HZ-09: MORE - Brake Pressure Duration"
          guideWord="MORE" parameter="Brake pressure duration"
          deviationText="Brakes remain applied after AEB deactivation command"
          riskLevel="CRITICAL" asil="D">
        <causes id="HZ_009_C1" name="Solenoid valve stuck open"/>
        <causes id="HZ_009_C2" name="Control signal latch-up"/>
        <consequences id="HZ_009_X1"
            name="Continuous braking at highway speed causing wheel lock and vehicle instability"/>
        <safeguards id="HZ_009_S1" name="Valve position feedback"/>
        <safeguards id="HZ_009_S2" name="Pressure relief valve"/>
        <safeguards id="HZ_009_S3" name="ABS override"/>
        <recommendations id="HZ_009_R1"
            name="Fail-safe valve design with spring-return, ABS arbitration"/>
      </deviations>

      <deviations id="HZ_015" name="HZ-15: PART OF - Braking Deceleration"
          guideWord="PART OF" parameter="Achieved deceleration"
          deviationText="AEB achieves only partial deceleration below 0.3g instead of required 0.5g urban or 0.7g highway"
          riskLevel="HIGH" asil="C">
        <causes id="HZ_015_C1" name="Hydraulic pressure loss"/>
        <causes id="HZ_015_C2" name="Partial valve opening"/>
        <causes id="HZ_015_C3" name="Degraded pump performance"/>
        <consequences id="HZ_015_X1"
            name="Collision not avoided, injury severity increased though not maximum"/>
        <safeguards id="HZ_015_S1" name="Deceleration monitoring"/>
        <safeguards id="HZ_015_S2" name="Pressure sensor feedback"/>
        <safeguards id="HZ_015_S3" name="Degraded mode warning"/>
        <recommendations id="HZ_015_R1"
            name="Minimum deceleration monitoring with driver alert on under-performance"/>
      </deviations>
    </nodes>

    <!-- =================== Node: CAN Bus =================== -->
    <nodes id="N_CAN" name="CAN Communication Bus"
        subsystem="CAN Communication Bus"
        designIntent="Carry radar object data from sensor to ECU within FTTI">

      <deviations id="HZ_010" name="HZ-10: NO SIGNAL - CAN Bus Radar to ECU"
          guideWord="NO" parameter="Radar data message"
          deviationText="No CAN messages received from radar by ECU"
          riskLevel="MEDIUM" asil="B">
        <causes id="HZ_010_C1" name="CAN transceiver failure"/>
        <causes id="HZ_010_C2" name="Bus-off state"/>
        <causes id="HZ_010_C3" name="Wiring open circuit"/>
        <consequences id="HZ_010_X1"
            name="ECU has no sensor input, AEB enters safe state if E2E detects loss"/>
        <safeguards id="HZ_010_S1" name="CAN E2E profile"/>
        <safeguards id="HZ_010_S2" name="Bus-off recovery"/>
        <safeguards id="HZ_010_S3" name="Message timeout detection at 50ms"/>
        <recommendations id="HZ_010_R1"
            name="E2E CRC plus sequence counter per ISO 26262 Part 6 Annex D"/>
      </deviations>

      <deviations id="HZ_011" name="HZ-11: OTHER THAN - CAN Message Content"
          guideWord="OTHER THAN" parameter="Radar message data integrity"
          deviationText="Corrupted or spoofed radar data on CAN bus"
          riskLevel="HIGH" asil="C">
        <causes id="HZ_011_C1" name="EMI induced bit errors"/>
        <causes id="HZ_011_C2" name="Bus fault"/>
        <causes id="HZ_011_C3" name="Missing E2E protection"/>
        <consequences id="HZ_011_X1"
            name="ECU acts on false obstacle data, wrong AEB decision"/>
        <safeguards id="HZ_011_S1" name="E2E CRC 8-bit"/>
        <safeguards id="HZ_011_S2" name="Sequence counter"/>
        <safeguards id="HZ_011_S3" name="Message authentication"/>
        <recommendations id="HZ_011_R1"
            name="ISO 26262 Part 6 E2E library profile 2 for radar CAN messages"/>
      </deviations>
    </nodes>

    <!-- =================== Node: Camera Sensor =================== -->
    <nodes id="N_Camera" name="Camera Sensor"
        subsystem="Camera Sensor"
        designIntent="Detect pedestrians and confirm radar targets visually">

      <deviations id="HZ_012" name="HZ-12: NO DETECTION - Camera Pedestrian Night"
          guideWord="NO" parameter="Pedestrian detection in low light"
          deviationText="Camera fails to detect pedestrian below 1 lux illumination"
          riskLevel="CRITICAL" asil="D">
        <causes id="HZ_012_C1" name="Insufficient sensor sensitivity"/>
        <causes id="HZ_012_C2" name="No IR illumination"/>
        <causes id="HZ_012_C3" name="Lens contamination"/>
        <consequences id="HZ_012_X1"
            name="No AEB response to pedestrian, fatality risk"/>
        <safeguards id="HZ_012_S1" name="Radar fallback for VRU detection"/>
        <safeguards id="HZ_012_S2" name="IR illuminator"/>
        <safeguards id="HZ_012_S3" name="Lens heater"/>
        <recommendations id="HZ_012_R1"
            name="IR illumination mandatory for nighttime CPNA compliance per Euro NCAP VRU v4.5.1"/>
      </deviations>
    </nodes>

    <!-- =================== Node: ECU-Brake Interface =================== -->
    <nodes id="N_Interface" name="AEB ECU to Brake Actuator Interface"
        subsystem="AEB ECU to Brake Actuator Interface"
        designIntent="Carry brake apply/release commands from ECU to hydraulic actuator without inversion">

      <deviations id="HZ_013" name="HZ-13: REVERSE - Brake Command Polarity"
          guideWord="REVERSE" parameter="Brake command signal polarity"
          deviationText="Brake release command sent instead of brake apply command"
          riskLevel="CRITICAL" asil="D">
        <causes id="HZ_013_C1" name="Signal inversion in software"/>
        <causes id="HZ_013_C2" name="Incorrect pin mapping"/>
        <causes id="HZ_013_C3" name="Hardware fault"/>
        <consequences id="HZ_013_X1"
            name="AEB attempts braking but releases any existing brake pressure"/>
        <safeguards id="HZ_013_S1" name="Command range plausibility check"/>
        <safeguards id="HZ_013_S2" name="Signed command with checksum"/>
        <recommendations id="HZ_013_R1"
            name="Hardware and software independent polarity verification at integration test"/>
      </deviations>
    </nodes>

    <!-- =================== Node: ECU Decision Logic =================== -->
    <nodes id="N_Decision" name="AEB ECU Decision Logic"
        subsystem="AEB ECU Decision Logic"
        designIntent="Activate AEB only when sensor fusion confirms imminent collision">

      <deviations id="HZ_014" name="HZ-14: EARLY - AEB Activation"
          guideWord="EARLY" parameter="AEB activation timing"
          deviationText="AEB activates at TTC above threshold with no real threat"
          riskLevel="HIGH" asil="C">
        <causes id="HZ_014_C1" name="TTC threshold miscalibration"/>
        <causes id="HZ_014_C2" name="False sensor fusion confirmation"/>
        <consequences id="HZ_014_X1"
            name="Unnecessary braking, driver discomfort, following vehicle risk"/>
        <safeguards id="HZ_014_S1" name="Dual sensor confirmation"/>
        <safeguards id="HZ_014_S2" name="TTC hysteresis"/>
        <safeguards id="HZ_014_S3" name="Driver override"/>
        <recommendations id="HZ_014_R1"
            name="TTC threshold validation per Euro NCAP CCRb scenario test protocol"/>
      </deviations>
    </nodes>

  </analyses>
</raaml:SafetyAnalysis>
