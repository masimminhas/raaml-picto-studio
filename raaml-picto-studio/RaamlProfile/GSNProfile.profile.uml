  <packagedElement xmi:type="uml:Stereotype" xmi:id="_qv5SMKEPEe--IdNhyvDzEg" name="SupportedBy">
    <ownedRule xmi:type="uml:Constraint" xmi:id="_njWLwKEREe--IdNhyvDzEg" name="ClientOfInContextMustbeGSNArgumentNode">
      <specification xmi:type="uml:OpaqueExpression" xmi:id="_njXZ4KEREe--IdNhyvDzEg" name="constraintSpec">
        <language>OCL</language>
        <body>GSNArgumentNode.allInstances().base_Element->includesAll(self.base_Dependency.client)&#xD;
</body>
      </specification>
    </ownedRule>
    <ownedRule xmi:type="uml:Constraint" xmi:id="_HKrl4KESEe--IdNhyvDzEg" name="ClientStrategythensuppliermustbeGoal.">
      <specification xmi:type="uml:OpaqueExpression" xmi:id="_HKsM8KESEe--IdNhyvDzEg" name="constraintSpec">
        <language>OCL</language>
        <body>Strategy.allInstances().base_Class->includesAll(self.base_Dependency.client)&#xD;
implies&#xD;
Goal.allInstances().base_Class->includesAll(self.base_Dependency.supplier)</body>
      </specification>
    </ownedRule>
    <ownedRule xmi:type="uml:Constraint" xmi:id="_W_C2gKESEe--IdNhyvDzEg" name="SupplierIsNotContextuaInformation">
      <specification xmi:type="uml:OpaqueExpression" xmi:id="_W_DdkKESEe--IdNhyvDzEg" name="constraintSpec">
        <language>OCL</language>
        <body>not ContextualInformation.allInstances().base_Element->includesAll(self.base_Dependency.supplier)</body>
      </specification>
    </ownedRule>
    <ownedRule xmi:type="uml:Constraint" xmi:id="_ihTYwKESEe--IdNhyvDzEg" name="ClientIsNotUndeveloped">
      <specification xmi:type="uml:OpaqueExpression" xmi:id="_ihUm4KESEe--IdNhyvDzEg" name="constraintSpec">
        <language>OCL</language>
        <body>not Undeveloped.allInstances().base_Element->includesAll(self.base_Dependency.client)</body>
      </specification>
    </ownedRule>
