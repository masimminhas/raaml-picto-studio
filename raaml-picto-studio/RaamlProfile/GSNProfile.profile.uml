  <packagedElement xmi:type="uml:Stereotype" xmi:id="_d8XVUKEPEe--IdNhyvDzEg" name="InContextOf">
    <ownedRule xmi:type="uml:Constraint" xmi:id="_xCTrcKEPEe--IdNhyvDzEg" name="ClientMustBeGSNArgumentNode">
      <specification xmi:type="uml:OpaqueExpression" xmi:id="_xCVgoKEPEe--IdNhyvDzEg" name="constraintSpec">
        <language>OCL</language>
        <body>not GSNNode.allInstances().base_Element->includesAll(self.base_Dependency.supplier)&#xD;
</body>
      </specification>
    </ownedRule>
    <ownedRule xmi:type="uml:Constraint" xmi:id="_I5tlcKEQEe--IdNhyvDzEg" name="SuppliercanbeContextualInfoORNonGSNbutNotGSNNode">
      <specification xmi:type="uml:OpaqueExpression" xmi:id="_I5uzkKEQEe--IdNhyvDzEg" name="constraintSpec">
        <language>OCL</language>
        <body>ContextualInformation.allInstances().base_Element->includesAll(self.base_Dependency.supplier)</body>
      </specification>
    </ownedRule>
