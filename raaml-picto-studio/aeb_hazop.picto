<?nsuri picto?>
<picto format="egx"
       transformation="platform:/resource/raaml-picto-studio/hazop_table.egx"
       standalone="true">
    <model type="EMF">
        <parameter name="name" value="M"/>
        <parameter name="metamodelFile"
                   value="platform:/resource/edu.kit.sdq.raaml/model/raaml.ecore"/>
        <parameter name="modelFile" value="raaml-picto-studio/aeb_hazop.raaml.xmi"/>
    </model>
</picto>
