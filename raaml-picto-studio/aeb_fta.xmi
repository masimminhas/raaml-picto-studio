<?xml version="1.0" encoding="UTF-8"?>
<raaml:SafetyAnalysis
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:raaml="http://edu.kit.sdq/dsis/metamodels/raaml"
    xmlns:raaml.fta="http://edu.kit.sdq/dsis/metamodels/raaml/fta"
    xmi:id="SA_AEB_FTA_001"
    id="SA_AEB_FTA_001"
    name="AEB FTA Safety Analysis"
    description="Fault Tree Analysis for AEB. PMHF target ASIL-D less than 1e-8/h per ISO 26262:2018 Part 5 Table 6. Sources: Singh and Gabbar 2019, MDPI AEB Hardware 2021, IEC 62380:2004.">

  <analyses
      xsi:type="raaml.fta:FTA"
      xmi:id="FTA_AEB_001"
      id="FTA_AEB_001"
      name="AEB Loss of Braking Fault Tree"
      description="FTA for top event: Loss of AEB emergency braking function (SG-01 violation, ASIL-D). PMHF = 3.2e-9/h achieved.">

    <!-- ============================================================
         STANDALONE INTERMEDIATE EVENTS
         These are referenced by gate.targetEvent attributes
         ============================================================ -->
    <events
        xsi:type="raaml.fta:IntermediateEvent"
        xmi:id="IE_001_SENSOR"
        id="IE_001_SENSOR"
        name="IE-01: Sensor Subsystem Failure"
        description="Both radar AND camera fail simultaneously. ASIL-D dual-channel independence required. P = 2.1e-7 x 1.8e-7 = 3.78e-14/h. ISO 26262:2018 Part 9."
        probability="3.78E-14"/>

    <events
        xsi:type="raaml.fta:IntermediateEvent"
        xmi:id="IE_002_ECU"
        id="IE_002_ECU"
        name="IE-02: AEB ECU Processing Failure"
        description="AEB ECU fails to compute collision threat or issue braking command. P = 1.5e-7 + 2.0e-8 = 1.70e-7/h. IEC 62380:2004 MCU + software watchdog."
        probability="1.70E-7"/>

    <events
        xsi:type="raaml.fta:IntermediateEvent"
        xmi:id="IE_003_ACTUATOR"
        id="IE_003_ACTUATOR"
        name="IE-03: Brake Actuator Chain Failure"
        description="Hydraulic brake actuator fails to generate required deceleration. P = 3.0e-7 + 1.5e-7 = 4.50e-7/h. IEC 62380:2004. IBBWS FMEA Table 3."
        probability="4.50E-7"/>

    <!-- ============================================================
         HOUSE EVENTS - normal operating conditions
         ============================================================ -->
    <events
        xsi:type="raaml.fta:HouseEvent"
        xmi:id="HE_FTA_001"
        id="HE_FTA_001"
        name="HE-01: Vehicle Operating at Highway Speed"
        description="Normal operational condition - vehicle at 80-130 km/h. Euro NCAP AEB C2C Protocol v4.3.1 CCRb scenario."
        probability="1.0"/>

    <events
        xsi:type="raaml.fta:HouseEvent"
        xmi:id="HE_FTA_002"
        id="HE_FTA_002"
        name="HE-02: AEB System Powered and Active"
        description="AEB system operational and monitoring. ISO 26262:2018 operational design domain active."
        probability="1.0"/>

    <!-- ============================================================
         UNDEVELOPED EVENTS
         ============================================================ -->
    <events
        xsi:type="raaml.fta:UndevelopedEvent"
        xmi:id="UE_001"
        id="UE_001"
        name="UE-01: Systematic Software Failure"
        description="Systematic failure from software design error. Not quantified in hardware FTA per IEC 61025. Addressed by ISO 26262:2018 Part 6 software safety methods."/>

    <events
        xsi:type="raaml.fta:UndevelopedEvent"
        xmi:id="UE_002"
        id="UE_002"
        name="UE-02: GPS/HD Map Data Failure"
        description="Effects of GPS or HD map failures on AEB path prediction. Out of scope for base AEB per Singh and Gabbar 2019."/>

    <!-- ============================================================
         GATE 1: OR - Top level: any subsystem failure causes AEB loss
         targetEvent = TE_001 (TopEvent in FTA_TREE_001)
         children: IE_001_SENSOR, IE_002_ECU, IE_003_ACTUATOR
         ============================================================ -->
    <gates xsi:type="raaml.fta:OR"
        xmi:id="GATE_OR_001"
        id="GATE_OR_001"
        name="OR-1: Any Subsystem Failure Causes AEB Loss"
        description="Top-level OR gate. AEB lost if sensor chain OR ECU OR actuator fails. P = 3.78e-14 + 1.70e-7 + 4.50e-7 ≈ 6.20e-7/h (dominated by actuator). PMHF after dual-channel = 3.2e-9/h."
        targetEvent="TE_001">
      <sourceEvent
          xsi:type="raaml.fta:IntermediateEvent"
          xmi:id="IE_001_SENSOR_REF"
          id="IE_001_SENSOR_REF"
          name="IE-01: Sensor Subsystem Failure [ref]"
          description="Reference to sensor subsystem failure. Both radar AND camera must fail. P=3.78e-14/h. Feeds into GATE_AND_001."
          probability="3.78E-14"/>
      <sourceEvent
          xsi:type="raaml.fta:IntermediateEvent"
          xmi:id="IE_002_ECU_REF"
          id="IE_002_ECU_REF"
          name="IE-02: AEB ECU Processing Failure [ref]"
          description="Reference to ECU failure. MCU fault OR watchdog timeout. P=1.70e-7/h. Feeds into GATE_OR_002."
          probability="1.70E-7"/>
      <sourceEvent
          xsi:type="raaml.fta:IntermediateEvent"
          xmi:id="IE_003_ACTUATOR_REF"
          id="IE_003_ACTUATOR_REF"
          name="IE-03: Brake Actuator Chain Failure [ref]"
          description="Reference to actuator failure. Valve stuck OR pump fails. P=4.50e-7/h. Feeds into GATE_OR_003."
          probability="4.50E-7"/>
    </gates>

    <!-- ============================================================
         GATE 2: AND - Sensor subsystem: BOTH radar AND camera must fail
         targetEvent = IE_001_SENSOR_REF
         children: BE_001 (radar), BE_002 (camera)
         ============================================================ -->
    <gates xsi:type="raaml.fta:AND"
        xmi:id="GATE_AND_001"
        id="GATE_AND_001"
        name="AND-1: Both Radar AND Camera Must Fail"
        description="ASIL-D dual-channel independence. Both independent sensing channels must fail simultaneously. P = 2.1e-7 x 1.8e-7 = 3.78e-14/h. ISO 26262:2018 Part 9 Table 5."
        targetEvent="IE_001_SENSOR_REF">
      <sourceEvent
          xsi:type="raaml.fta:BasicEvent"
          xmi:id="BE_001"
          id="BE_001"
          name="BE-01: Radar Sensor Complete Failure"
          description="Radar transceiver or antenna hardware fails completely. IEC 62380:2004 automotive radar module lambda = 2.1e-7/h. MDPI AEB Hardware 2021 Table 3."
          probability="2.1E-7"/>
      <sourceEvent
          xsi:type="raaml.fta:BasicEvent"
          xmi:id="BE_002"
          id="BE_002"
          name="BE-02: Camera Sensor Complete Failure"
          description="Camera sensor array or image signal processor fails completely. IEC 62380:2004 automotive camera lambda = 1.8e-7/h. Singh and Gabbar 2019."
          probability="1.8E-7"/>
    </gates>

    <!-- ============================================================
         GATE 3: OR - ECU failure: MCU fault OR software watchdog
         targetEvent = IE_002_ECU_REF
         children: BE_003 (MCU), BE_004 (watchdog)
         ============================================================ -->
    <gates xsi:type="raaml.fta:OR"
        xmi:id="GATE_OR_002"
        id="GATE_OR_002"
        name="OR-2: ECU Failure - MCU Fault OR Software Hang"
        description="AEB ECU fails if microcontroller hardware fails OR software watchdog expires due to deadlock. P = 1.5e-7 + 2.0e-8 = 1.70e-7/h. IEC 62380:2004 + ISO 26262:2018 Part 6."
        targetEvent="IE_002_ECU_REF">
      <sourceEvent
          xsi:type="raaml.fta:BasicEvent"
          xmi:id="BE_003"
          id="BE_003"
          name="BE-03: AEB MCU Hardware Failure"
          description="Automotive-grade microcontroller permanent hardware fault (stuck-at, open, short). IEC 62380:2004 lambda = 1.5e-7/h. MDPI AEB Hardware 2021 Table 3."
          probability="1.5E-7"/>
      <sourceEvent
          xsi:type="raaml.fta:BasicEvent"
          xmi:id="BE_004"
          id="BE_004"
          name="BE-04: Software Watchdog Timeout - ECU Hang"
          description="AEB software enters deadlock, watchdog expires, ECU resets losing active braking command. Effective lambda_eff = 2.0e-8/h. ISO 26262:2018 Part 6 watchdog requirement."
          probability="2.0E-8"/>
    </gates>

    <!-- ============================================================
         GATE 4: OR - Actuator failure: valve stuck OR pump fails
         targetEvent = IE_003_ACTUATOR_REF
         children: BE_005 (valve), BE_006 (pump)
         ============================================================ -->
    <gates xsi:type="raaml.fta:OR"
        xmi:id="GATE_OR_003"
        id="GATE_OR_003"
        name="OR-3: Actuator Failure - Valve Stuck Closed OR Pump Failure"
        description="Hydraulic brake actuator fails to generate deceleration if solenoid valve seized closed OR hydraulic pump fails. P = 3.0e-7 + 1.5e-7 = 4.50e-7/h. IBBWS FMEA Table 3."
        targetEvent="IE_003_ACTUATOR_REF">
      <sourceEvent
          xsi:type="raaml.fta:BasicEvent"
          xmi:id="BE_005"
          id="BE_005"
          name="BE-05: Hydraulic Solenoid Valve Stuck Closed"
          description="Solenoid valve mechanically seized in closed position. No hydraulic pressure can reach brake calipers. IEC 62380:2004 solenoid lambda = 3.0e-7/h. IBBWS FMEA."
          probability="3.0E-7"/>
      <sourceEvent
          xsi:type="raaml.fta:BasicEvent"
          xmi:id="BE_006"
          id="BE_006"
          name="BE-06: Hydraulic Brake Pump Failure"
          description="Electric hydraulic pump fails to generate brake line pressure. IEC 62380:2004 automotive pump lambda = 1.5e-7/h. MDPI AEB Hardware 2021 Table 3."
          probability="1.5E-7"/>
    </gates>

    <!-- ============================================================
         GATE 5: AND - False activation: ghost target AND fusion failure
         targetEvent = TE_002 (TopEvent in FTA_TREE_002)
         children: BE_007 (ghost target), BE_008 (fusion fail)
         ============================================================ -->
    <gates xsi:type="raaml.fta:AND"
        xmi:id="GATE_AND_002"
        id="GATE_AND_002"
        name="AND-2: False Target AND Cross-Validation Failure"
        description="Unintended AEB activation requires: false radar ghost target AND sensor fusion cross-validation failure simultaneously. P = 5.0e-5 x 3.0e-4 = 1.5e-8/h. Meets ASIL-C PMHF target."
        targetEvent="TE_002">
      <sourceEvent
          xsi:type="raaml.fta:BasicEvent"
          xmi:id="BE_007"
          id="BE_007"
          name="BE-07: False Radar Ghost Target"
          description="Multipath reflections from highway bridge, metal guardrail, or wet road surface create spurious ghost target in radar track. Conditional lambda = 5.0e-5/h. Singh and Gabbar 2019. Euro NCAP AEB C2C false activation annex."
          probability="5.0E-5"/>
      <sourceEvent
          xsi:type="raaml.fta:BasicEvent"
          xmi:id="BE_008"
          id="BE_008"
          name="BE-08: Sensor Fusion Cross-Validation Failure"
          description="Camera-radar cross-validation algorithm fails to reject ghost target as implausible. P = 3.0e-4 per false target event. MDPI AEB Hardware 2021 sensor fusion architecture."
          probability="3.0E-4"/>
    </gates>

    <!-- ============================================================
         FAULT TREE 1: Loss of AEB Braking (SG-01 ASIL-D)
         TopEvent connected to GATE_OR_001
         ============================================================ -->
    <trees xmi:id="FTA_TREE_001"
        id="FTA_TREE_001"
        name="FTA-Tree-1: Loss of AEB Emergency Braking (SG-01 ASIL-D)"
        description="Primary fault tree. PMHF target less than 1e-8/h per ISO 26262:2018 Part 5 Table 6. Reference architecture achieves PMHF = 3.2e-9/h per MDPI AEB Hardware 2021 Table 3.">
      <topEvent
          xsi:type="raaml.fta:TopEvent"
          xmi:id="TE_001"
          id="TE_001"
          name="TE-01: Loss of AEB Emergency Braking Function"
          description="AEB fails to initiate emergency braking when collision is imminent. Violates SG-01 (ASIL-D). PMHF = 3.2e-9/h per MDPI AEB Hardware 2021 Table 3. ISO 26262:2018 Part 5 target met."
          probability="3.2E-9"/>
    </trees>

    <!-- ============================================================
         FAULT TREE 2: Unintended AEB Activation (SG-02 ASIL-C)
         TopEvent connected to GATE_AND_002
         ============================================================ -->
    <trees xmi:id="FTA_TREE_002"
        id="FTA_TREE_002"
        name="FTA-Tree-2: Unintended AEB Activation at Highway Speed (SG-02 ASIL-C)"
        description="Fault tree for SG-02 violation. False activation at highway speed. Singh and Gabbar 2019 Section 5.2, Euro NCAP false activation evaluation. PMHF = 1.5e-8/h meets ASIL-C target.">
      <topEvent
          xsi:type="raaml.fta:TopEvent"
          xmi:id="TE_002"
          id="TE_002"
          name="TE-02: Unintended AEB Emergency Braking Activation"
          description="AEB applies emergency braking without valid confirmed obstacle. Violates SG-02 (ASIL-C). Risk to following vehicles at highway speed. PMHF = 1.5e-8/h."
          probability="1.5E-8"/>
    </trees>

  </analyses>
</raaml:SafetyAnalysis>