<?xml version="1.0" encoding="UTF-8"?>
<raaml:SafetyAnalysis
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:raaml="http://edu.kit.sdq/dsis/metamodels/raaml"
    xmlns:raaml.hara="http://edu.kit.sdq/dsis/metamodels/raaml/hara"
    xmlns:raaml.req="http://edu.kit.sdq/dsis/metamodels/raaml/req"
    xmlns:raaml.core="http://edu.kit.sdq/dsis/metamodels/raaml/core"
    xmi:id="SA_AEB_001"
    id="SA_AEB_001"
    name="AEB Safety Analysis - HARA"
    description="ISO 26262 Hazard Analysis and Risk Assessment for AEB System">

  <analyses xsi:type="raaml.hara:ISO26262"
      xmi:id="HARA_AEB_001"
      id="HARA_AEB_001"
      name="AEB HARA Analysis"
      description="Hazard analysis following ISO 26262:2018 Part 3.">

    <operationalSituations xsi:type="raaml.hara:OperationalSituation"
        xmi:id="OS_001" id="OS_001"
        name="OS-01: Urban Driving - Following Vehicle"
        description="Vehicle following lead vehicle at urban speed 10-50 km/h. Euro NCAP CCRs and CCRm scenarios. High exposure daily commute. [Source: Euro NCAP AEB C2C Protocol v4.3.1]"/>

    <operationalSituations xsi:type="raaml.hara:OperationalSituation"
        xmi:id="OS_002" id="OS_002"
        name="OS-02: Highway Driving - High Speed"
        description="Vehicle at highway speed 80-130 km/h closing on lead vehicle. Euro NCAP CCRb scenario. [Source: Euro NCAP AEB C2C Protocol v4.3.1]"/>

    <operationalSituations xsi:type="raaml.hara:OperationalSituation"
        xmi:id="OS_003" id="OS_003"
        name="OS-03: Pedestrian Crossing - Day"
        description="Pedestrian crossing at 20-60 km/h daytime. Euro NCAP CPNA day scenario. [Source: Euro NCAP AEB VRU Protocol v4.5.1]"/>

    <operationalSituations xsi:type="raaml.hara:OperationalSituation"
        xmi:id="OS_004" id="OS_004"
        name="OS-04: Pedestrian Crossing - Night"
        description="Pedestrian crossing at night reduced sensor performance. Euro NCAP CPNA night scenario. [Source: Euro NCAP AEB VRU Protocol v4.5.1]"/>

    <operationalSituations xsi:type="raaml.hara:OperationalSituation"
        xmi:id="OS_005" id="OS_005"
        name="OS-05: Low Speed Parking Manoeuvre"
        description="Vehicle at 0-15 km/h in parking area. AEB active but false activation risk elevated. [Source: Euro NCAP AEB C2C Protocol v4.3.1]"/>

    <operationalSituations xsi:type="raaml.hara:OperationalSituation"
        xmi:id="OS_006" id="OS_006"
        name="OS-06: Adverse Weather - Rain/Fog"
        description="Vehicle in rain or fog reducing sensor performance. [Source: ISO 26262:2018 Part 3 Annex B; Singh and Gabbar 2019]"/>

    <malfunctioningBehaviors xsi:type="raaml.hara:MalfunctioningBehaviour"
        xmi:id="MB_001" id="MB_001"
        name="MB-01: Loss of Braking Function"
        description="AEB completely fails to initiate braking when collision imminent. [Source: Singh and Gabbar 2019 FM-1]"/>

    <malfunctioningBehaviors xsi:type="raaml.hara:MalfunctioningBehaviour"
        xmi:id="MB_002" id="MB_002"
        name="MB-02: Unintended Braking Activation"
        description="AEB applies emergency braking when no obstacle present. [Source: Singh and Gabbar 2019 FM-2]"/>

    <malfunctioningBehaviors xsi:type="raaml.hara:MalfunctioningBehaviour"
        xmi:id="MB_003" id="MB_003"
        name="MB-03: Degraded Braking Performance"
        description="AEB applies partial braking insufficient to avoid collision. [Source: Singh and Gabbar 2019 FM-3]"/>

    <malfunctioningBehaviors xsi:type="raaml.hara:MalfunctioningBehaviour"
        xmi:id="MB_004" id="MB_004"
        name="MB-04: Delayed Braking Activation"
        description="AEB initiates braking later than required time window. [Source: ISO 26262:2018 Part 3]"/>

    <malfunctioningBehaviors xsi:type="raaml.hara:MalfunctioningBehaviour"
        xmi:id="MB_005" id="MB_005"
        name="MB-05: Erroneous Object Classification"
        description="Radar or camera incorrectly classifies obstacles. [Source: Singh and Gabbar 2019 FM-4]"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ASIL_HE_001" id="ASIL_HE_001"
        name="ASIL Assignment HE-01"
        description="HE-01: MB-01 Loss of Braking in OS-01 Urban Following. S3 life-threatening collision at 50km/h. E4 daily commute. C3 driver cannot avoid in time window less than 1.5s. Result: ASIL D. [ISO 26262:2018 Part 3 Table 4; SAE J2980 Table 1]"
        ASIL="D"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ASIL_HE_002" id="ASIL_HE_002"
        name="ASIL Assignment HE-02"
        description="HE-02: MB-01 Loss of Braking in OS-02 Highway. S3 high-speed collision fatalities probable. E3 frequent motorway travel. C3 no driver reaction possible above 120km/h. Result: ASIL D. [ISO 26262:2018 Part 3 Table 4]"
        ASIL="D"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ASIL_HE_003" id="ASIL_HE_003"
        name="ASIL Assignment HE-03"
        description="HE-03: MB-02 Unintended Braking in OS-02 Highway. S3 following vehicle rear-end at 130km/h. E3 highway exposure. C2 following driver may partially react. Result: ASIL C. [ISO 26262:2018 Part 3 Table 4]"
        ASIL="C"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ASIL_HE_004" id="ASIL_HE_004"
        name="ASIL Assignment HE-04"
        description="HE-04: MB-01 Loss of Braking in OS-03 Pedestrian Day. S3 pedestrian fatality. E4 daily urban driving. C3 pedestrian cannot avoid vehicle. Result: ASIL D. [Euro NCAP VRU Protocol v4.5.1]"
        ASIL="D"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ASIL_HE_005" id="ASIL_HE_005"
        name="ASIL Assignment HE-05"
        description="HE-05: MB-01 Loss of Braking in OS-04 Pedestrian Night. S3 pedestrian fatality. E3 less frequent night driving. C3 pedestrian unaware. Result: ASIL D. [Euro NCAP VRU Protocol v4.5.1]"
        ASIL="D"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ASIL_HE_006" id="ASIL_HE_006"
        name="ASIL Assignment HE-06"
        description="HE-06: MB-03 Degraded Braking in OS-01 Urban. S2 serious injury probable. E4 daily exposure. C2 driver may supplement braking. Result: ASIL B. [ISO 26262:2018 Part 3 Table 4]"
        ASIL="B"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ASIL_HE_007" id="ASIL_HE_007"
        name="ASIL Assignment HE-07"
        description="HE-07: MB-02 Unintended Braking in OS-05 Parking. S1 minor injury at low speed. E3 regular parking. C2 driver can override. Result: QM. [ISO 26262:2018 Part 3 Table 4]"
        ASIL="QM"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ASIL_HE_008" id="ASIL_HE_008"
        name="ASIL Assignment HE-08"
        description="HE-08: MB-04 Delayed Braking in OS-02 Highway. S3 delayed activation renders AEB ineffective. E3 highway exposure. C3 no driver reaction time. Result: ASIL D. [MDPI AEB 2021 FTTI analysis]"
        ASIL="D"/>

    <asilAssignments xsi:type="raaml.hara:ASILAssignment"
        xmi:id="ASIL_HE_009" id="ASIL_HE_009"
        name="ASIL Assignment HE-09"
        description="HE-09: MB-05 Erroneous Classification in OS-06 Adverse Weather. S3 undetected collision in fog. E2 adverse weather less frequent. C3 driver visibility also impaired. Result: ASIL C. [Singh and Gabbar 2019]"
        ASIL="C"/>

    <verifiedItems xsi:type="raaml.hara:Verified"
        xmi:id="VER_001" id="VER_001"
        name="HARA Verification"
        result="Verified against ISO 26262:2018 Part 3. All ASIL assignments cross-checked with SAE J2980:2018 Table 1. Operational situations validated against Euro NCAP AEB C2C v4.3.1 and VRU v4.5.1."/>

    <confirmedItems xsi:type="raaml.hara:Confirmed"
        xmi:id="CONF_001" id="CONF_001"
        name="HARA Confirmation"
        result="Safety goals SG-01 through SG-05 derived from ASIL-D and ASIL-C hazardous events. Confirmed by independent review against Singh and Gabbar 2019 AEB safety analysis results."/>

  </analyses>

  <requirements xsi:type="raaml.req:RequirementsModel"
      xmi:id="REQ_MODEL_001" id="REQ_MODEL_001"
      name="AEB Safety Requirements Model"
      description="Safety goals and functional safety requirements derived from HARA per ISO 26262:2018 Part 4">

    <requirements xsi:type="raaml.req:SafetyGoal"
        xmi:id="SG_001" id="SG_001"
        name="SG-01: Prevent Unmitigated Rear-End Collision"
        text="The AEB system shall prevent unmitigated rear-end collisions with lead vehicles by initiating emergency braking when TTC falls below system threshold."
        description="Derived from HE-01 ASIL-D urban and HE-02 ASIL-D highway. Source: Singh and Gabbar 2019; ISO 26262:2018 Part 3 Table 4."
        type="SafetyGoal" priority="high" status="approved"/>

    <requirements xsi:type="raaml.req:SafetyGoal"
        xmi:id="SG_002" id="SG_002"
        name="SG-02: Prevent Unintended Emergency Braking at Highway Speed"
        text="The AEB system shall not apply emergency braking in absence of a confirmed obstacle with sensor fusion confidence above defined threshold at speeds above 80 km/h."
        description="Derived from HE-03 ASIL-C. Source: ISO 26262:2018 Part 3; Euro NCAP false activation criteria."
        type="SafetyGoal" priority="high" status="approved"/>

    <requirements xsi:type="raaml.req:SafetyGoal"
        xmi:id="SG_003" id="SG_003"
        name="SG-03: Prevent Pedestrian Fatality"
        text="The AEB system shall detect pedestrians on a collision course and initiate emergency braking in both daytime and nighttime conditions."
        description="Derived from HE-04 ASIL-D and HE-05 ASIL-D. Source: Euro NCAP VRU Protocol v4.5.1."
        type="SafetyGoal" priority="high" status="approved"/>

    <requirements xsi:type="raaml.req:SafetyGoal"
        xmi:id="SG_004" id="SG_004"
        name="SG-04: Ensure Braking Within Fault Tolerant Time Interval"
        text="The AEB system shall initiate braking response within FTTI of 150ms at highway speeds and 300ms at urban speeds."
        description="Derived from HE-08 ASIL-D. FTTI values from MDPI AEB Hardware 2021. Source: ISO 26262:2018 Part 4 Clause 8.4.6."
        type="SafetyGoal" priority="high" status="approved"/>

    <requirements xsi:type="raaml.req:SafetyGoal"
        xmi:id="SG_005" id="SG_005"
        name="SG-05: Maintain AEB Operation in Adverse Weather"
        text="The AEB system shall maintain at least degraded braking function in adverse weather with appropriate driver warning."
        description="Derived from HE-09 ASIL-C. Source: Singh and Gabbar 2019."
        type="SafetyGoal" priority="medium" status="approved"/>

    <requirements xsi:type="raaml.req:FunctionalSafetyRequirement"
        xmi:id="FSR_001" id="FSR_001"
        name="FSR-01: Radar Sensor Availability"
        text="The forward-looking radar sensor shall maintain continuous obstacle detection with PMHF not exceeding 1e-8 per hour."
        description="Derived from SG-01. Source: ISO 26262:2018 Part 5 Table 6; MDPI AEB 2021."
        type="FunctionalSafetyRequirement" priority="high" status="approved"/>

    <requirements xsi:type="raaml.req:FunctionalSafetyRequirement"
        xmi:id="FSR_002" id="FSR_002"
        name="FSR-02: AEB ECU Fault Detection and Safe State"
        text="The AEB ECU shall detect internal faults and transition to safe state within FTTI."
        description="Derived from SG-01. Source: ISO 26262:2018 Part 4 Clause 8.4.5."
        type="FunctionalSafetyRequirement" priority="high" status="approved"/>

    <requirements xsi:type="raaml.req:TechnicalSafetyRequirement"
        xmi:id="TSR_001" id="TSR_001"
        name="TSR-01: Minimum Deceleration Threshold"
        text="The AEB system shall achieve minimum deceleration of 0.5g in urban and 0.7g in highway scenarios."
        description="Derived from FSR-01. Source: Euro NCAP AEB C2C Protocol v4.3.1 Section 4.2."
        type="TechnicalSafetyRequirement" priority="high" status="approved"/>

    <requirements xsi:type="raaml.req:SoftwareSafetyRequirement"
        xmi:id="SSR_001" id="SSR_001"
        name="SSR-01: Sensor Fusion Algorithm Integrity"
        text="The sensor fusion software shall implement two independent obstacle detection algorithms with cross-validation logic."
        description="Derived from FSR-02. Source: ISO 26262:2018 Part 6."
        type="SoftwareSafetyRequirement" priority="high" status="approved"/>

    <requirements xsi:type="raaml.req:HardwareSafetyRequirement"
        xmi:id="HSR_001" id="HSR_001"
        name="HSR-01: Radar Sensor Hardware Fault Tolerance"
        text="The radar sensor hardware shall implement HFT=1 for the primary detection channel."
        description="Derived from TSR-01. Source: ISO 26262:2018 Part 5 Table 4."
        type="HardwareSafetyRequirement" priority="high" status="approved"/>

    <derivations xsi:type="raaml.req:DeriveRequirement"
        xmi:id="DERIVE_001" id="DERIVE_001"
        name="SG-01 derives FSR-01">
      <source href="#SG_001"/>
      <target href="#FSR_001"/>
    </derivations>

    <derivations xsi:type="raaml.req:DeriveRequirement"
        xmi:id="DERIVE_002" id="DERIVE_002"
        name="SG-01 derives FSR-02">
      <source href="#SG_001"/>
      <target href="#FSR_002"/>
    </derivations>

    <derivations xsi:type="raaml.req:DeriveRequirement"
        xmi:id="DERIVE_003" id="DERIVE_003"
        name="FSR-01 derives TSR-01">
      <source href="#FSR_001"/>
      <target href="#TSR_001"/>
    </derivations>

    <derivations xsi:type="raaml.req:DeriveRequirement"
        xmi:id="DERIVE_004" id="DERIVE_004"
        name="FSR-02 derives SSR-01">
      <source href="#FSR_002"/>
      <target href="#SSR_001"/>
    </derivations>

    <derivations xsi:type="raaml.req:ASILDecompose"
        xmi:id="DERIVE_005" id="DERIVE_005"
        name="ASIL-D Decomposition SG-01 to HSR-01">
      <source href="#SG_001"/>
      <target href="#HSR_001"/>
    </derivations>

  </requirements>

</raaml:SafetyAnalysis>