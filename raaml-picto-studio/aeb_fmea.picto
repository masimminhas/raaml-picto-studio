<?nsuri picto?>
<picto format="egx"
       transformation="platform:/plugin/raaml-picto-studio/picto/fmea_table.egx"
       standalone="true">
    <model type="EMF">
        <parameter name="name" value="M"/>
        <parameter name="metamodelUri" value="http://www.kit.edu/sdq/raaml"/>
        <parameter name="modelFile"
                   file="platform:/resource/${project.name}/instances/aeb_fmea.xmi"/>
    </model>
</picto>
