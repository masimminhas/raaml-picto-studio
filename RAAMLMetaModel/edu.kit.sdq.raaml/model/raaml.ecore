        <details key="base" value="Abstraction"/>
        <details key="stereotype" value="UserInfoRequirement"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="RecoveryRequirement" eSuperTypes="#//req/Satisfy">
