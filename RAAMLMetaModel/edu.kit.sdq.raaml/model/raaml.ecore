    <eClassifiers xsi:type="ecore:EClass" name="ISO26262SafetyRequirementTemplate"
        eSuperTypes="#//req/DependabilityRequirement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Template for ISO 26262 safety requirements with ASIL and FTTI"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="ISO26262SafetyRequirementTemplate"/>
