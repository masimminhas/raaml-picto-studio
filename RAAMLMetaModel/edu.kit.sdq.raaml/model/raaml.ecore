          <details key="documentation" value="Ordered list of group members"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="ElementGroupBasedItem" eSuperTypes="#//core/Item #//core/ElementGroup">
