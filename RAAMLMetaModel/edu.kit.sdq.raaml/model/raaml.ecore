        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="The requirement text"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="type" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Type of requirement (functional, safety, etc.)"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="priority" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Priority level (high, medium, low)"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="status" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Current status (proposed, approved, implemented, verified)"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="relatedElements" upperBound="-1"
          eType="#//core/CoreSafetyElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Elements related to this requirement"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="parentRequirement" eType="#//req/Requirement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Parent requirement in the hierarchy"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="childRequirements" upperBound="-1"
          eType="#//req/Requirement" containment="true">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Child requirements in the hierarchy"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="RequirementComponent" abstract="true"
        eSuperTypes="#//core/CoreSafetyElement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Abstract base class for all requirement-related components"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EReference" name="haraOwner" eType="#//req/HazardAndRiskAssessment"
          eOpposite="#//req/HazardAndRiskAssessment/haraRequirements"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Abstraction" abstract="true" eSuperTypes="#//req/RequirementComponent">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Abstract base class for requirement relationships and abstractions"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Abstraction"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="DeriveRequirement" eSuperTypes="#//req/Abstraction">
