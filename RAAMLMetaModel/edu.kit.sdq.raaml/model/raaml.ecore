          eType="#//req/Requirement"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="target" lowerBound="1"
          eType="#//req/Requirement"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="IndependenceRequirement" eSuperTypes="#//req/DeriveRequirement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Requirement specifying independence between elements (ISO 26262)"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Abstraction"/>
        <details key="stereotype" value="IndependenceRequirement"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="ASILDecompose" eSuperTypes="#//req/DeriveRequirement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="ASIL decomposition relationship (ISO 26262) for distributing safety requirements"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Abstraction"/>
        <details key="stereotype" value="ASILDecompose"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Satisfy" eSuperTypes="#//req/Abstraction">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Relationship indicating a requirement satisfies another requirement or element"/>
