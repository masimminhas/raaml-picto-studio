<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="raaml" nsURI="http://edu.kit.sdq/dsis/metamodels/raaml" nsPrefix="raaml">
  <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
    <details key="documentation" value="Risk Analysis and Assessment Modeling Language (RAAML) - Pure Metamodel"/>
  </eAnnotations>
  <eClassifiers xsi:type="ecore:EClass" name="SafetyAnalysis" eSuperTypes="#//core/NamedElement">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Root container for all safety analyses, libraries, and requirements"/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
      <details key="base" value="Package"/>
      <details key="profile" value="RAAML"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EReference" name="analyses" upperBound="-1"
        eType="#//core/Analysis" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Collection of safety analyses (FTA, FMEA, HARA, STPA, GSN)"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="libraries" upperBound="-1"
        eType="#//core/AbstractLibrary" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Reusable libraries of safety elements"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="requirements" upperBound="-1"
        eType="#//req/RequirementsModel" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Safety requirements and their relationships"/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>
  <eSubpackages name="core" nsURI="http://edu.kit.sdq/dsis/metamodels/raaml/core"
      nsPrefix="raaml.core">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Core elements shared across all safety analysis types"/>
    </eAnnotations>
    <eClassifiers xsi:type="ecore:EClass" name="NamedElement" abstract="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Abstract base class for all named elements in RAAML"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="NamedElement"/>
