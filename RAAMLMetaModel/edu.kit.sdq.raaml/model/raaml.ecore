        <details key="documentation" value="An item composed of a group of elements"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="ElementGroupBasedItem"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="AnySituation" abstract="true" eSuperTypes="#//core/Situation">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Extended situation with causal relationships"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EReference" name="from" upperBound="-1"
          eType="#//core/AnySituation" eOpposite="#//core/AnySituation/to">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Situations that lead to this situation"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="to" upperBound="-1" eType="#//core/AnySituation"
          eOpposite="#//core/AnySituation/from">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Situations that result from this situation"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Factor" abstract="true" eSuperTypes="#//core/AnySituation">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="A causal factor contributing to hazards or failures"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="Factor"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EReference" name="processModelFlaw" upperBound="-1"
          eType="#//core/ProcessModelFlaw">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Process model flaws caused by this factor"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="ProcessModelFlaw" eSuperTypes="#//core/AnySituation">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="A flaw in the control process model (STPA)"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="ProcessModelFlaw"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EReference" name="causalFactor" upperBound="-1"
          eType="#//core/Factor">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Causal factors of this process model flaw"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="undesiredControlAction"
          upperBound="-1" eType="#//stpa/UndesiredControlAction">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Undesired control actions resulting from this flaw"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="HarmPotential" abstract="true" eSuperTypes="#//core/CoreSafetyElement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Potential for harm or adverse effects"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="HarmPotential"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EReference" name="undesiredControlAction"
          upperBound="-1" eType="#//stpa/UndesiredControlAction">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Undesired control actions with this harm potential"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="AbstractEvent" abstract="true" eSuperTypes="#//core/AnySituation">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Base class for events with likelihood"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="likelihood" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Probability or frequency of occurrence"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="DysfunctionalEvent" abstract="true"
        eSuperTypes="#//core/AbstractEvent">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Event representing dysfunctional behavior"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EReference" name="toError" upperBound="-1"
          eType="#//core/DysfunctionalEvent" eOpposite="#//core/DysfunctionalEvent/fromError">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Error events propagated to"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="fromError" upperBound="-1"
          eType="#//core/DysfunctionalEvent" eOpposite="#//core/DysfunctionalEvent/toError">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Error events propagated from"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="error" upperBound="-1"
          eType="#//core/DysfunctionalEvent" eOpposite="#//core/DysfunctionalEvent/failure">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Errors associated with this event"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="failure" upperBound="-1"
          eType="#//core/DysfunctionalEvent" eOpposite="#//core/DysfunctionalEvent/error">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Failures associated with this event"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="fault" upperBound="-1"
          eType="#//core/AbstractCause" eOpposite="#//core/AbstractCause/error">
