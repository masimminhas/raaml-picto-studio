      <eStructuralFeatures xsi:type="ecore:EAttribute" name="id" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Unique identifier for the element"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Human-readable name"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="description" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Detailed description of the element"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="visibility" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Visibility modifier (public, private, protected)"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Analysis" abstract="true" eSuperTypes="#//core/NamedElement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Base class for all safety analysis types"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Package"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EReference" name="elements" upperBound="-1"
          eType="#//core/CoreSafetyElement" containment="true">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Safety elements contained in this analysis"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="AbstractLibrary" abstract="true" eSuperTypes="#//core/NamedElement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Base class for reusable libraries of safety elements"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Package"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EReference" name="elements" upperBound="-1"
          eType="#//core/CoreSafetyElement" containment="true">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Reusable safety elements in this library"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="CoreSafetyElement" abstract="true"
        eSuperTypes="#//core/NamedElement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Base class for all safety-related elements"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Situation" eSuperTypes="#//core/CoreSafetyElement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="A state or condition in a system context"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="Situation"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="FailureMode" eSuperTypes="#//core/Situation">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="A manner in which a system or component can fail"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="FailureMode"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Hazard" eSuperTypes="#//core/Situation">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="A potential source of harm or damage"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="Hazard"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Error" eSuperTypes="#//core/Situation">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="A deviation from correct behavior"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="Error"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Fault" eSuperTypes="#//core/Situation">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="An abnormal condition that can cause a failure"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="Fault"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="ControllingMeasure" abstract="true"
        eSuperTypes="#//core/CoreSafetyElement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Base class for measures that control or mitigate risks"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="affects" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Description of what the measure affects"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Detection" eSuperTypes="#//core/ControllingMeasure">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Measure to detect failures or hazards"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="Detection"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Recommendation" eSuperTypes="#//core/ControllingMeasure">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Suggested action to address risks"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="Recommendation"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Mitigation" eSuperTypes="#//core/ControllingMeasure">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Measure to reduce the impact of a hazard"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="Mitigation"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Prevention" eSuperTypes="#//core/ControllingMeasure">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Measure to prevent a hazard from occurring"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="Prevention"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="State" abstract="true" eSuperTypes="#//core/CoreSafetyElement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="A condition or mode of a system"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="State"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="FailureState" eSuperTypes="#//core/State">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="A state representing a system failure"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="State"/>
        <details key="stereotype" value="FailureState"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="DirectedRelationship" abstract="true"
        eSuperTypes="#//core/CoreSafetyElement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Base class for directed relationships between safety elements"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Dependency"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EReference" name="source" upperBound="-1"
          eType="#//core/CoreSafetyElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Source elements of the relationship"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="target" upperBound="-1"
          eType="#//core/CoreSafetyElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Target elements of the relationship"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="RelevantTo" eSuperTypes="#//core/DirectedRelationship">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Indicates relevance relationship between elements"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Dependency"/>
        <details key="stereotype" value="RelevantTo"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="PresentIn" eSuperTypes="#//core/RelevantTo">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Indicates presence in a context"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Dependency"/>
        <details key="stereotype" value="PresentIn"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Violates" eSuperTypes="#//core/DirectedRelationship">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Indicates a violation of constraints or requirements"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Dependency"/>
        <details key="stereotype" value="Violates"/>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Item" abstract="true" eSuperTypes="#//core/CoreSafetyElement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="A system component or element under analysis"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="Item"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EReference" name="members" upperBound="-1"
          eType="#//core/CoreSafetyElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Internal components of the item"/>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="boundaryMembers" upperBound="-1"
          eType="#//core/CoreSafetyElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Elements at the boundary of the item"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="SingleElementItem" eSuperTypes="#//core/Item">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="An item that references a single element"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="SingleElementItem"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EReference" name="referencedElement" lowerBound="1"
          eType="#//core/Item">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="The referenced item element"/>
        </eAnnotations>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="ElementGroup" eSuperTypes="#//core/CoreSafetyElement">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="A logical grouping of safety elements"/>
      </eAnnotations>
      <eAnnotations source="http://edu.kit.sdq/raaml/metaclass">
        <details key="base" value="Class"/>
        <details key="stereotype" value="ElementGroup"/>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="groupCriterion" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
