<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore"
    name="sysmlblocks"
    nsURI="http://edu.kit.sdq/dsis/metamodels/sysml/blocks"
    nsPrefix="sysmlblocks">

  <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
    <details key="documentation"
             value="Standalone Ecore mirror of a minimal SysML Blocks profile
                    subset. Companion artefact to RAAML Picto Studio, used to
                    demonstrate that the profile-resolution-independent
                    round-trip pattern generalises beyond OMG RAAML."/>
  </eAnnotations>

  <!-- ===================================================================== -->
  <!-- Root container                                                         -->
  <!-- ===================================================================== -->
  <eClassifiers xsi:type="ecore:EClass" name="BlockModel">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation"
               value="Top-level container for a SysML Blocks model. Mirrors
                      the role of a UML Package owning Block stereotype
                      applications."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="id"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="blocks"
        upperBound="-1" eType="#//Block" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="constraintBlocks"
        upperBound="-1" eType="#//ConstraintBlock" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="valueTypes"
        upperBound="-1" eType="#//ValueType" containment="true"/>
  </eClassifiers>

  <!-- ===================================================================== -->
  <!-- Block  (base metaclass: Class)                                          -->
  <!-- ===================================================================== -->
  <eClassifiers xsi:type="ecore:EClass" name="Block">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation"
               value="SysML Block: an encapsulated unit of structural decomposition."/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/sysml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="Block"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="id"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="isEncapsulated"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"
        defaultValueLiteral="false"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="ownedProperties"
        upperBound="-1" eType="#//Property" containment="true"/>
  </eClassifiers>

  <!-- ===================================================================== -->
  <!-- ConstraintBlock  (base metaclass: Class, extends Block)                 -->
  <!-- ===================================================================== -->
  <eClassifiers xsi:type="ecore:EClass" name="ConstraintBlock"
      eSuperTypes="#//Block">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation"
               value="SysML ConstraintBlock: a Block whose body is a constraint expression."/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/sysml/metaclass">
      <details key="base" value="Class"/>
      <details key="stereotype" value="ConstraintBlock"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="constraintExpression"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>

  <!-- ===================================================================== -->
  <!-- Property  (base metaclass: Property)                                    -->
  <!-- ===================================================================== -->
  <eClassifiers xsi:type="ecore:EClass" name="Property">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation"
               value="Block-owned property. Non-Class base metaclass exercises
                      the base_* generalisation of stereotype detection."/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/sysml/metaclass">
      <details key="base" value="Property"/>
      <details key="stereotype" value="Property"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="id"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="typeName"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="lowerBound"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt"
        defaultValueLiteral="1"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="upperBound"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt"
        defaultValueLiteral="1"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="defaultValue"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>

  <!-- ===================================================================== -->
  <!-- FlowProperty  (base metaclass: Property, extends Property)              -->
  <!-- ===================================================================== -->
  <eClassifiers xsi:type="ecore:EClass" name="FlowProperty"
      eSuperTypes="#//Property">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation"
               value="A property representing flow of matter, energy, or
                      information at a Block boundary."/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/sysml/metaclass">
      <details key="base" value="Property"/>
      <details key="stereotype" value="FlowProperty"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="direction"
        eType="#//FlowDirection" defaultValueLiteral="inout"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="FlowDirection">
    <eLiterals name="in" value="0"/>
    <eLiterals name="out" value="1"/>
    <eLiterals name="inout" value="2" literal="inout"/>
  </eClassifiers>

  <!-- ===================================================================== -->
  <!-- ValueType  (base metaclass: DataType)                                   -->
  <!-- ===================================================================== -->
  <eClassifiers xsi:type="ecore:EClass" name="ValueType">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation"
               value="Typed primitive value with optional unit and dimension.
                      Demonstrates AnyType pattern over a DataType base, not Class."/>
    </eAnnotations>
    <eAnnotations source="http://edu.kit.sdq/sysml/metaclass">
      <details key="base" value="DataType"/>
      <details key="stereotype" value="ValueType"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="id"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="unit"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="dimension"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>

</ecore:EPackage>
