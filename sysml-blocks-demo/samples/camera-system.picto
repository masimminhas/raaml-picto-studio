<?nsuri picto?>
<picto format="egx"
       transformation="platform:/resource/sysml-blocks-demo/views/blocks.egx"
       standalone="true">
    <model type="EMF">
        <parameter name="name" value="M"/>
        <parameter name="metamodelFile"
                   value="platform:/resource/sysml-blocks-demo/model/sysml-blocks.ecore"/>
        <parameter name="modelFile"
                   value="sysml-blocks-demo/samples/camera-system.sysml-blocks.xmi"/>
    </model>
</picto>
